conky.config = {
-- vim: textwidth=0
	alignment = 'top_left',
	gap_x = 6,
	gap_y = 4,
	maximum_width = 1920,
--font -*-terminus-*-*-*-*-12-*-*-*-*-*-*-*

	use_xft = true,
	font = 'DejaVu Sans Mono:size=17',
--xftfont Terminus:size=10
	override_utf8_locale = true,
	default_color = '#CCCCCC',
	out_to_console = false,
	update_interval = 2.5,
	draw_shades = false,
	double_buffer = true,
	text_buffer_size = 8096,
};

conky.text = [[

${color #FFFFFF}down: ${color #CCCCCC}${downspeedf wlp8s0}KiB/s${offset 30}${color #FFFFFF}up: ${color #CCCCCC}${upspeedf wlp8s0}KiB/s
${downspeedgraph wlp8s0 60,200 CCCCCC FFFFFF} ${upspeedgraph wlp8s0 60,200 CCCCCC FFFFFF}
${color #FFFFFF}disk I/O       memory: $mem
${diskiograph 60,200 CCCCCC FFFFFF} ${memgraph 60,200 CCCCCC FFFFFF}
${color #CCCCCC}${swapbar 20,300} swap: $swap

${fs_bar 20,150 /} /      ${fs_used /} of ${fs_size /}
${fs_bar 20,150 /home} /home  ${fs_used /home} of ${fs_size /home}
${fs_bar 20,150 /mnt/lenslowssd} /mnt/lenslowssd  ${fs_used /mnt/lenslowssd} of ${fs_size /mnt/lenslowssd}

${color #CCCCCC}${cpu cpu0}%${offset 20} ${color #CCCCCC}${cpu cpu1}%${offset 20} ${color #CCCCCC}${cpu cpu2}%${offset 20} ${color #CCCCCC}${cpu cpu3}%${offset 20}${cpu cpu4}%${offset 20} ${color #CCCCCC}${cpu cpu5}%${offset 20} ${color #CCCCCC}${cpu cpu6}%${offset 20} ${color #CCCCCC}${cpu cpu7}%
${cpugraph cpu0 60,50 CCCCCC FFFFFF} ${cpugraph cpu1 60,50 CCCCCC FFFFFF} ${cpugraph cpu2 60,50 CCCCCC FFFFFF} ${cpugraph cpu3 60,50 CCCCCC FFFFFF} ${cpugraph cpu4 60,50 CCCCCC FFFFFF} ${cpugraph cpu5 60,50 CCCCCC FFFFFF} ${cpugraph cpu6 60,50 CCCCCC FFFFFF} ${cpugraph cpu7 60,50 CCCCCC FFFFFF}

${texeci 600 ~/scripts/exchange-rates.sh}

nvme0n1 ${exec cat /tmp/nvme-temp}°C  sda ${hddtemp /dev/sda}°C

${exec ~/scripts/temp.sh}

${exec ~/scripts/co2mond-status.sh}

#${texeci 3 ~/scripts/ping-mind.sh}

#${texeci 60 ~/scripts/touchpad-status.sh}

#${execpi 300 PYTHONIOENCODING=utf8 gcalcli --conky --nolineart calm --monday}
]];
